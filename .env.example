# Environment
ENVIRONMENT=development

# PostgreSQL
POSTGRES_USER=emsi_user
POSTGRES_PASSWORD=emsi_pass
POSTGRES_DB=emsi_portail
POSTGRES_PORT=5433

# Backend database URL used inside Docker network
DATABASE_URL=postgresql://emsi_user:emsi_pass@db:5432/emsi_portail

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# Security
# In production, replace this with a long random value.
# Example generation:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-in-production-local-key-please-change
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS / Frontend
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001

# Ports
BACKEND_PORT=8001
FRONTEND_PORT=3000

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=portail@emsi.ma

# Alert thresholds
SEUIL_ABSENCE_ALERTE=30
SEUIL_NOTE_ALERTE=10