# Database
DATABASE_URL=postgresql://emsi_user:emsi_pass@db:5432/emsi_portail

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Email (optional - leave empty to log emails instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=portail@emsi.ma

# Risk thresholds
SEUIL_ABSENCE_ALERTE=30
SEUIL_NOTE_ALERTE=10

# Environment
ENVIRONMENT=development
